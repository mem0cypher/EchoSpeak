# Echo Speak Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# MODEL PROVIDER SELECTION
# ============================================================================
# Set to "true" to use local models instead of OpenAI
USE_LOCAL_MODELS=false

USE_TOOL_CALLING_LLM=false
LM_STUDIO_TOOL_CALLING=false

# Local model provider: ollama, lmstudio, localai, llama_cpp, vllm
LOCAL_MODEL_PROVIDER=ollama

# ============================================================================
# OPENAI CONFIGURATION (used when USE_LOCAL_MODELS=false)
# ============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# ============================================================================
# GEMINI CONFIGURATION (used when MODEL_PROVIDER=gemini)
# ============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=8192

# ============================================================================
# LOCAL MODEL CONFIGURATION (used when USE_LOCAL_MODELS=true)
# ============================================================================

# Ollama Settings
# Install: https://ollama.com
# Run: ollama run qwen3:8b (or llama3, mistral, etc.)
# URL for local model provider
LOCAL_MODEL_URL=http://localhost:11434
# Model name for local model provider
LOCAL_MODEL_NAME=llama3.2
LOCAL_MODEL_TEMPERATURE=0.7
LOCAL_MODEL_MAX_TOKENS=4096
LOCAL_MODEL_CONTEXT=8192
LOCAL_MODEL_GPU_LAYERS=-1

# LM Studio (GGUF direct, OpenAI-compatible)
# LOCAL_MODEL_PROVIDER=lmstudio
# LOCAL_MODEL_NAME=your-model-id-here
# LOCAL_MODEL_URL=http://localhost:1234

# LocalAI Settings
# LOCAL_MODEL_PROVIDER=localai
# LOCAL_MODEL_URL=http://localhost:8080

# llama.cpp Settings
# LOCAL_MODEL_PROVIDER=llama_cpp
# LOCAL_MODEL_NAME=/path/to/your/model.gguf

# vLLM Settings
# LOCAL_MODEL_PROVIDER=vllm
# LOCAL_MODEL_URL=http://localhost:8000

# ============================================================================
# EMBEDDING MODEL CONFIGURATION
# ============================================================================
# Provider for embeddings: openai, ollama, lmstudio
# - openai: requires OPENAI_API_KEY
# - lmstudio: uses LOCAL_MODEL_URL (OpenAI-compatible /v1 endpoint); no OpenAI key required
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# If using LM Studio embeddings, set:
# EMBEDDING_PROVIDER=lmstudio
# EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Local embedding settings
LOCAL_EMBEDDING_PATH=/path/to/embedding/model
LOCAL_EMBEDDING_TYPE=nomic-embed-text

# ==========================================================================
# DOCUMENT RAG + CONTEXT MANAGEMENT
# ==========================================================================
DOCUMENT_RAG_ENABLED=true
DOC_UPLOAD_MAX_MB=25

# Context + citations
DOC_CONTEXT_MAX_CHARS=2800
DOC_CONTEXT_SHOW_LABELS=true
DOC_SOURCE_PREVIEW_CHARS=160

# Hybrid retrieval + reranking
DOC_HYBRID_ENABLED=false
DOC_VECTOR_K=30
DOC_BM25_K=30
DOC_FINAL_K=5
DOC_CANDIDATE_K=0
DOC_RRF_K=60

DOC_RERANK_ENABLED=false
DOC_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
DOC_RERANK_K=30

# GraphRAG-lite expansion
DOC_GRAPH_ENABLED=false
DOC_GRAPH_EXPAND_K=12
DOC_GRAPH_MAX_ENTITIES=8
DOC_GRAPH_QUERY_ENTITIES=8

SUMMARY_TRIGGER_TURNS=18
SUMMARY_KEEP_LAST_TURNS=6

ACTION_PLAN_ENABLED=true

# LLM-driven action parser pass (single-action JSON). When enabled, EchoSpeak interprets user intent into a structured action
# before falling back to heuristic tool routing.
ACTION_PARSER_ENABLED=true

MEMORY_PARTITION_ENABLED=false

# LLM context trimming (0 = auto)
LLM_TRIM_MAX_TOKENS=0
LLM_TRIM_RESERVE_TOKENS=512

# ============================================================================
# WEB SEARCH SETTINGS
# ============================================================================
WEB_SEARCH_TIMEOUT=10

TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=8

# Optional: block low-quality/duplicated domains from web_search results.
# Comma-separated domains, e.g. "msn.com, pinterest.com".
WEB_SEARCH_BLOCKED_DOMAINS=

# ============================================================================
# SPOTIFY INTEGRATION
# ============================================================================
# Spotify requires a loopback IP redirect URI; localhost is not allowed.
ALLOW_SPOTIFY=false
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_TOKEN_PATH=

# ============================================================================
# TWITTER/X INTEGRATION
# ============================================================================
# Master switch — set to true to enable the Twitter/X bot
ALLOW_TWITTER=false

# OAuth 1.0a credentials (X Developer Portal → Keys and Tokens)
# "Consumer Key" → TWITTER_CLIENT_ID, "Consumer Secret" → TWITTER_CLIENT_SECRET
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# Optional: bot user ID (auto-detected on startup via get_me if omitted)
TWITTER_BOT_USER_ID=

# Mention polling
TWITTER_AUTO_REPLY_MENTIONS=false
TWITTER_POLL_INTERVAL=120

# Autonomous tweeting — Echo composes and posts tweets on a schedule
TWITTER_AUTONOMOUS_ENABLED=false
# Interval between tweet ticks in minutes (minimum 30)
TWITTER_AUTONOMOUS_INTERVAL=120
# Max tweets per day
TWITTER_AUTONOMOUS_MAX_DAILY=6
# Require owner approval before posting (RECOMMENDED: true)
TWITTER_AUTONOMOUS_REQUIRE_APPROVAL=true

# ==========================================================================
# TESSERACT OCR SETTINGS (Windows)
# ==========================================================================
# Download from: https://github.com/UB-Mannheim/tesseract/wiki
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Safety gates (system actions)
ENABLE_SYSTEM_ACTIONS=false
ALLOW_OPEN_CHROME=false
ALLOW_PLAYWRIGHT=false
ALLOW_DESKTOP_AUTOMATION=false
ALLOW_FILE_WRITE=false
ALLOW_TERMINAL_COMMANDS=false
TERMINAL_COMMAND_ALLOWLIST=git,rg,ls,cat,find,grep,sed,awk,head,tail,pwd,jq,python,python3,uv,pytest,npm,npx,node,pip,pip3,go,make,pnpm,yarn,bun,cargo
TERMINAL_COMMAND_TIMEOUT=20
TERMINAL_MAX_OUTPUT_CHARS=8000
FILE_TOOL_ROOT=.

# Recommended (Linux) coding-agent safe defaults:
# - Enable system actions and explicitly allow file writes + terminal commands.
# - Restrict terminal commands via a first-token allowlist.
# - Restrict file/terminal working directory to FILE_TOOL_ROOT.
# ENABLE_SYSTEM_ACTIONS=true
# ALLOW_FILE_WRITE=true
# ALLOW_TERMINAL_COMMANDS=true
# TERMINAL_COMMAND_ALLOWLIST=git,rg,ls,cat,python,uv,pytest,npm,go,make
# FILE_TOOL_ROOT=/absolute/path/to/your/workspace

# Workspace profiles (slash command):
# - /onboard (list profiles)
# - /onboard coding | research | chat

# Notes:
# - .env flags are hard safety switches (deployment gates).
# - Workspaces/skills shape behavior and restrict which tools can be proposed; skills cannot expand tool access beyond the workspace.

# Where artifact_write/notepad_write will save output files (defaults to ./data/artifacts)
ARTIFACTS_DIR=

# ==========================================================================
# MULTI-SESSION + OPS (agents, commands, triggers)
# ==========================================================================
SKILLS_DIR=
WORKSPACES_DIR=

# Enable multi-agent pool keyed by thread_id
MULTI_AGENT_ENABLED=true

# Slash command controls (agent-side)
# Example: ALLOWED_COMMANDS=/commands,/skills,/workspaces,/workspace,/doctor
ALLOWED_COMMANDS=
COMMAND_PREFIX=/

# Triggers
CRON_ENABLED=false
CRON_STATE_PATH=

WEBHOOK_ENABLED=false
WEBHOOK_SECRET=
WEBHOOK_SECRET_PATH=

# ============================================================================
# HEARTBEAT — System Pulse (Proactive Mode)
# ============================================================================
# Echo wakes on a schedule, gathers real system state (todos, git, twitter,
# time), and decides if anything is worth reporting. Silent ticks cost nothing.
HEARTBEAT_ENABLED=false
# Minutes between heartbeat ticks (minimum ~10)
HEARTBEAT_INTERVAL=30
# Output channels: web, discord, telegram, email (comma-separated)
HEARTBEAT_CHANNELS=web,discord
# Custom prompt (leave blank for the built-in system pulse prompt)
# HEARTBEAT_PROMPT=

# ============================================================================
# PERSONAPLEX STREAMING AUDIO
# ============================================================================
PERSONAPLEX_ENABLED=false
PERSONAPLEX_URL=ws://localhost:8998/api/chat
PERSONAPLEX_TEXT_PROMPT=
PERSONAPLEX_VOICE_PROMPT=
PERSONAPLEX_VOICE=
PERSONAPLEX_AUDIO_TEMPERATURE=0.7
PERSONAPLEX_TEXT_TEMPERATURE=0.7
PERSONAPLEX_AUDIO_TOPK=50
PERSONAPLEX_TEXT_TOPK=50
PERSONAPLEX_SAMPLE_RATE=24000
PERSONAPLEX_CHANNELS=1
PERSONAPLEX_FRAME_MS=20
PERSONAPLEX_INPUT_DEVICE=
PERSONAPLEX_OUTPUT_DEVICE=
PERSONAPLEX_QUERY=
PERSONAPLEX_HANDSHAKE_JSON=
PERSONAPLEX_SSL_VERIFY=true
PERSONAPLEX_CONNECT_TIMEOUT=10
PERSONAPLEX_PING_INTERVAL=20
PERSONAPLEX_PING_TIMEOUT=20

# ============================================================================
# API SERVER SETTINGS
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Admin API key for protected endpoints (/admin/restart, etc.)
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
# If not set, a random key will be generated on startup (check logs)
ADMIN_API_KEY=
